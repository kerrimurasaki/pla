{
  "name": "pla-core",
  "version": "0.1.0",
  "description": "Personal Learning Agent — Phase 1-3 core engine: schemas, invariants, event log, mode contracts, pipeline, plus a minimal Next.js API wrapper for Vercel test deploys",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "eval:classifier": "tsx evals/run-classifier-eval.ts",
    "pla": "tsx src/cli.ts",
    "build:lib": "tsc -p tsconfig.build.json",
    "predev": "npm run build:lib",
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "npm run build:lib && next build",
    "start": "next start"
  },
  "dependencies": {
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
